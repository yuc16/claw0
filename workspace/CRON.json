{
  "jobs": [
    {
      "id": "morning-briefing",
      "name": "Morning Briefing",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 9 * * *",
        "tz": "Asia/Shanghai"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Check today's calendar, weather forecast, and any pending reminders. Give a brief morning summary."
      },
      "delete_after_run": false
    },
    {
      "id": "afternoon-briefing",
      "name": "afternoon Briefing",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "43 15 * * *",
        "tz": "Asia/Shanghai"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "向我问好."
      },
      "delete_after_run": false
    },
    {
      "id": "dep-security-scan",
      "name": "Dependency Security Scan",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 9 * * 1",
        "tz": "Asia/Shanghai"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Run a security audit on project dependencies. Report any critical vulnerabilities."
      },
      "delete_after_run": false
    },
    {
      "id": "health-check",
      "name": "System Health Check",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "every_seconds": 3600,
        "anchor": "2026-02-24T00:00:00+08:00"
      },
      "payload": {
        "kind": "agent_turn",
        "message": "Check system health: memory usage, disk space, and running services. Report only if something needs attention."
      },
      "delete_after_run": false
    }
  ]
}
