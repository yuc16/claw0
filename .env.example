# OpenAI Codex OAuth Configuration
# Login with a ChatGPT Plus/Pro account:
#   uv run python login_openai_codex.py
MODEL_ID=gpt-5.4

# Optional: override the Codex endpoint
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex/responses

# Optional: tag requests with a custom originator string
# OPENAI_CODEX_ORIGINATOR=claw0

# Optional: disable auto-starting interactive OAuth on the first model call
# OPENAI_CODEX_AUTO_LOGIN=1

# Optional: retry with insecure SSL when your local cert store is broken
# OPENAI_CODEX_VERIFY_SSL=1

# Telegram (optional, for s04_channels.py)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Feishu / Lark (optional, for s04_channels.py)
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_DOMAIN=feishu    # "feishu" for domestic, "lark" for international

# Heartbeat (optional, for s07_heartbeat_cron.py)
# HEARTBEAT_INTERVAL=1800
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22
